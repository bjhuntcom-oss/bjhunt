# ============================================================================
# BJHUNT ALPHA 1.0 — Environment Variables
# ============================================================================
# Copy to .env and fill in all REQUIRED values
# Generate secrets with: openssl rand -hex 32

# ── Frontend (Next.js) ───────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://api.bjhunt.com
BACKEND_API_URL=http://127.0.0.1:3001
HCAPTCHA_SECRET=                 # Server-side hCaptcha secret (used by /api/contact, /api/beta)
NEXT_PUBLIC_HCAPTCHA_SITEKEY=    # Public hCaptcha sitekey for the widget (contact + beta forms)
RESEND_API_KEY=

# ── Backend (Hono+Bun) ──────────────────────────────────────────────────
SESSION_SECRET=           # REQUIRED — openssl rand -hex 32
ENCRYPTION_KEY=           # REQUIRED in prod — AES-256-GCM key (openssl rand -base64 32)
                          # Used to encrypt provider API keys at rest (Finding #3-36 / C-14)
BJHUNT_APP_DATABASE_URL=  # REQUIRED in prod — postgres://bjhunt_app:<password>@postgres:5432/bjhunt
CORS_ORIGINS=https://bjhunt.com,https://www.bjhunt.com

# ── Shared Secrets ───────────────────────────────────────────────────────
BJHUNT_API_SECRET=        # REQUIRED — shared between backend + LangGraph
POSTGRES_PASSWORD=        # REQUIRED — openssl rand -hex 32
NEO4J_PASSWORD=           # REQUIRED — openssl rand -hex 32
LITELLM_MASTER_KEY=       # REQUIRED — openssl rand -hex 32
LITELLM_SALT_KEY=         # REQUIRED — openssl rand -hex 32

# ── LLM API Keys (at least one required) ────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_CLOUD_API_KEY=

# ── Model Profile ───────────────────────────────────────────────────────
BJHUNT_MODEL_PROFILE=eco  # eco | max | test

# ── Versions ─────────────────────────────────────────────────────────────
BJHUNT_VERSION=latest

# ── Stripe (W10 — leave empty to keep /api/billing/{checkout,portal,webhook}
# returning 501 stripe_not_configured. Filling these activates the routes.) ─
STRIPE_SECRET_KEY=        # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=    # whsec_... from `stripe listen` or dashboard
STRIPE_PRICE_PRO=         # price_... for the Pro plan
STRIPE_PRICE_ENTERPRISE=  # price_... for the Enterprise plan

# ── Observability stack (opt-in, see ops/observability/) ─────────────────
GRAFANA_ADMIN_PASSWORD=   # REQUIRED only if starting the observability overlay

# ── Sentry (W11 — leave empty to disable Sentry init at boot) ─────────────
SENTRY_DSN=               # https://...@sentry.io/...
SENTRY_ENVIRONMENT=production
