# ============================================================================
# BJHUNT ALPHA 1.0 — Environment Variables
# ============================================================================
# Copy to .env and fill in all REQUIRED values
# Generate secrets with: openssl rand -hex 32

# ── Frontend (Next.js) ───────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://api.bjhunt.com
BACKEND_API_URL=http://127.0.0.1:3001
HCAPTCHA_SECRET=
RESEND_API_KEY=

# ── Backend (Hono+Bun) ──────────────────────────────────────────────────
SESSION_SECRET=           # REQUIRED — openssl rand -hex 32
CORS_ORIGINS=https://bjhunt.com,https://www.bjhunt.com

# ── Shared Secrets ───────────────────────────────────────────────────────
BJHUNT_API_SECRET=        # REQUIRED — shared between backend + LangGraph
POSTGRES_PASSWORD=        # REQUIRED — openssl rand -hex 32
NEO4J_PASSWORD=           # REQUIRED — openssl rand -hex 32
LITELLM_MASTER_KEY=       # REQUIRED — openssl rand -hex 32
LITELLM_SALT_KEY=         # REQUIRED — openssl rand -hex 32

# ── LLM API Keys (at least one required) ────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=
OLLAMA_CLOUD_API_KEY=

# ── Model Profile ───────────────────────────────────────────────────────
BJHUNT_MODEL_PROFILE=eco  # eco | max | test

# ── Versions ─────────────────────────────────────────────────────────────
BJHUNT_VERSION=latest
