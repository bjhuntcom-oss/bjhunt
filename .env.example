# BJHUNT Frontend — Environment variables
# Copy to .env.local and fill in for local dev. In production, set these in Vercel.

# ── Email (Resend) — beta + contact forms ──────────
RESEND_API_KEY=

# ── hCaptcha — anti-spam on beta + contact ────────
NEXT_PUBLIC_HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# ── Upstash Redis — rate limiting (optional in dev: falls back in-memory) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── PostHog — product analytics (optional) ────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
