# =============================================================================
# Decepticon — Environment Variables
# =============================================================================
# The installer copies this file to ~/.decepticon/.env
# Edit with: decepticon config

# --- LLM API Keys (required: at least one) ---
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
# GOOGLE_API_KEY=your-google-key-here
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key-here

# --- LiteLLM Proxy --- (REQUIRED — generate with: openssl rand -hex 32)
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=

# --- PostgreSQL --- (REQUIRED — generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=

# --- Neo4j (Attack Chain Graph DB) --- (REQUIRED — generate with: openssl rand -hex 32)
NEO4J_PASSWORD=

# --- BJHUNT API Secret --- (REQUIRED — generate with: openssl rand -hex 32)
# Shared secret between BJHUNT backend and LangGraph API for auth
BJHUNT_API_SECRET=

# --- Model Profile ---
# eco  = Balanced (Opus/Sonnet/Haiku mix, recommended)
# max  = Maximum performance (Opus everywhere, expensive)
# test = Cheapest (Haiku-only, for development)
BJHUNT_MODEL_PROFILE=eco

# --- LangSmith Tracing (optional) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key-here
# LANGSMITH_PROJECT=bjhunt

# --- Ports (optional) ---
# LANGGRAPH_PORT=2024
# LITELLM_PORT=4000
# POSTGRES_PORT=5432

# --- C2 Framework ---
# Default C2 server profile. Change to swap C2 frameworks.
# Options: c2-sliver (default), c2-havoc (future)
COMPOSE_PROFILES=c2-sliver

# --- Paths ---
# Install directory (used for workspace bind mount into containers).
# - Production: The installer sets this to ~/.bjhunt automatically.
# - Development: `bjhunt` (Python entry point) sets this to the repo root automatically.
# Do not use ~ (tilde) — Docker Compose cannot expand it.
# BJHUNT_HOME=/home/youruser/.bjhunt

# --- Advanced (optional) ---
# BJHUNT_DEBUG=true
