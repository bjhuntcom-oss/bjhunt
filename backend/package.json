{
  "name": "@bjhunt/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/ --diagnostic-level=error",
    "test": "bun test --pass-with-no-tests",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "0.7.6",
    "@sentry/bun": "^10.50.0",
    "argon2": "0.44.0",
    "fflate": "^0.8.2",
    "hono": "4.12.15",
    "ioredis": "5.10.1",
    "nanoid": "5.1.9",
    "otpauth": "9.5.1",
    "postgres": "3.4.9",
    "resend": "^4.0.0",
    "stripe": "^22.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "1.3.13",
    "typescript": "^5.7.0"
  }
}
