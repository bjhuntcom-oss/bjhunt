# BJHUNT Backend — Environment Variables
# Copy to .env and fill in values

# --- Server ---
PORT=3001
NODE_ENV=development

# --- PostgreSQL --- (REQUIRED)
DATABASE_URL=postgresql://bjhunt:YOUR_PASSWORD@localhost:5432/bjhunt

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth --- (REQUIRED — generate with: openssl rand -hex 32)
SESSION_SECRET=

# --- Secret encryption key (REQUIRED in production) ---
# AES-256-GCM key for provider API keys stored in gateway_providers. Generate:
#   openssl rand -base64 32
# If unset in development, the backend derives one from SESSION_SECRET (see
# backend/src/lib/crypto.ts). In production the process will refuse to start
# without this value.
ENCRYPTION_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://bjhunt.com,https://www.bjhunt.com

# --- LangGraph API ---
LANGGRAPH_URL=http://localhost:2024
BJHUNT_API_SECRET=  # Must match engine's BJHUNT_API_SECRET
