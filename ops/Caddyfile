api.bjhunt.com {
    # CORS is handled entirely by the Hono backend (cors middleware).
    # Caddy only adds security headers and proxies without buffering.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    reverse_proxy backend:3001 {
        flush_interval -1
    }
}

:80 {
    respond /health "OK" 200
}
