{
    email admin@bjhunt.com
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

api.bjhunt.com, chat.bjhunt.com {
    # Streaming routes — ZERO buffering, no compression
    @streaming path /stream/*
    handle @streaming {
        reverse_proxy backend:3001 {
            flush_interval -1
            transport http {
                compression off
                read_timeout 0
                write_timeout 0
            }
        }
    }

    # Chat SSE prep + stream (also under /api/chat/stream/*)
    @chat_stream path /api/chat/stream/*
    handle @chat_stream {
        reverse_proxy backend:3001 {
            flush_interval -1
            transport http {
                compression off
                read_timeout 0
                write_timeout 0
            }
        }
    }

    # Health checks (no rate limit, fast path)
    handle /api/health/* {
        reverse_proxy backend:3001
    }

    # All other API routes
    handle /* {
        reverse_proxy backend:3001
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"

        # VPS-P1-6: API edge serves JSON only — no scripts, no styles, no
        # images. CSP locked to `default-src 'none'` + `connect-src 'self'`
        # (so the JSON parser inside the browser fetch is allowed) and
        # `frame-ancestors 'none'` to belt-and-braces XFO=DENY. report-uri
        # collects violations at the backend's CSP-report endpoint.
        Content-Security-Policy "default-src 'none'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'; report-uri /api/security/csp-report"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-site"
        Reporting-Endpoints "default=\"/api/security/csp-report\""
        -Server
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h
        }
        format json
    }
}

:80 {
    respond /health "OK" 200
}
