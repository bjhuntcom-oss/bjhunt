{
  email contact@bjhunt.com
}

chat.bjhunt.com {
  encode gzip zstd

  header {
    -Server
  }

  @websocket {
    header Connection *Upgrade*
    header Upgrade websocket
  }

  # WebSocket: require BJHUNT session auth before proxying to gateway
  handle @websocket {
    forward_auth backend:3001 {
      uri /api/auth/gateway-check
      copy_headers X-Forwarded-User
    }

    reverse_proxy bjhunt-gateway:18789
  }

  # HTTP: require BJHUNT session auth before serving the control UI
  handle {
    forward_auth backend:3001 {
      uri /api/auth/gateway-check
      copy_headers X-Forwarded-User
    }

    reverse_proxy bjhunt-gateway:18789
  }
}

api.bjhunt.com {
  encode gzip zstd

  header {
    -Server
  }

  @runtime path_regexp runtime ^/runtime/([0-9]+)(/.*)?$
  handle @runtime {
    forward_auth backend:3001 {
      uri /api/runtime/proxy-auth
      copy_headers X-Forwarded-User
    }

    reverse_proxy runtime-proxy:8080
  }

  reverse_proxy backend:3001
}
